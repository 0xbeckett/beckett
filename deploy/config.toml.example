# Beckett — every config key at its DEFAULT value (issue #34).
# The live file is ~/.beckett/config.toml on the box; only put keys you're OVERRIDING there
# (validation is strict: schema-pruned keys must be removed in the same deploy).
# Regenerate after any schema change:  bun src/cli/beckett.ts config print-default

[concurrency]
max_workers = 2

[supervise]
worker_hard_cap_s = 3600
worker_stall_s = 300
worker_checkpoint_s = 120

[models]
reviewer = "claude-sonnet-5"

[harness]
fallback_order = ["claude", "pi", "codex"]

[harness.claude]
bin = "claude"
default_model = "claude-sonnet-5"
default_effort = "xhigh"
permission_mode = "bypassPermissions"
extra_flags = ["--verbose", "--replay-user-messages", "--include-hook-events"]

[harness.codex]
enabled = false
bin = "codex"
default_model = ""
default_effort = "high"
sandbox_mode = "danger-full-access"
approval_policy = "never"
network_default = true

[harness.pi]
enabled = true
bin = "pi"
default_provider = "openai-codex"
default_model = "gpt-5.6-terra"
thinking = "high"

[paths]
home = "/home/beckett"
beckett_dir = "/home/beckett/.beckett"
projects = "/home/beckett/projects"
db = "/home/beckett/.beckett/beckett.db"
events_dir = "/home/beckett/.beckett/events"
logs_dir = "/home/beckett/.beckett/logs"
memory_dir = "/home/beckett/.beckett/memory"
socket = "/home/beckett/.beckett/beckett.sock"
spend = "/home/beckett/.beckett/spend.jsonl"

[identity]
github_user = "0xbeckett"
gmail_address = ""

[plane]
base_url = "https://plane.0xbeckett.me"
workspace_slug = "beckett"
poll_secs = 5
default_board = "ops"

[plane.boards.ops]
project_slug = "beckett"

[plane.boards.ops.state_map]
backlog = "Backlog"
todo = "Todo"
in_progress = "In Progress"
in_review = "In Review"
done = "Done"
cancelled = "Cancelled"

[plane.boards.int]
project_slug = "INT"

[plane.boards.int.state_map]
backlog = "Backlog"
todo = "Todo"
design = "Design"
design_review = "Review (Design)"
in_progress = "In Progress"
in_review = "Review"
done = "Done"
cancelled = "Cancelled"

[plane.boards.vid]
project_slug = "VID"

[plane.boards.vid.state_map]
backlog = "Ideas"
todo = "Scripting"
in_progress = "Production"
in_review = "Review"
done = "Published"
cancelled = "Shelved"

[plane.boards.vidpip]
project_slug = "VIDPIP"

[plane.boards.vidpip.state_map]
backlog = "Backlog"
todo = "Todo"
in_progress = "In Progress"
in_review = "In Review"
done = "Done"
cancelled = "Cancelled"

[github]
poll_secs = 60

[github.activity]
enabled = true
repo = "0xbeckett/beckett"
branch = "main"
poll_secs = 60
channel_id = "1520658476974735490"
ignored_authors = ["0xbeckett", "github-actions[bot]", "dependabot[bot]"]

[proactivity]
enabled = false
default_mode = "off"
triage_provider = "claude"
triage_threshold = 0.45
burst_quiet_secs = 20
engaged_quiet_secs = 4
channel_cooldown_secs = 60
max_interjections_per_hour = 0
engaged_window_secs = 180
offer_ttl_secs = 600
transcript_window = 15
triage_model = "claude-haiku-4-5"

[shared_context]
enabled = true
max_entries_per_channel = 200
max_age_hours = 72
inject_budget_tokens = 3000
roster_max = 12
profile_model = "claude-haiku-4-5"
profile_update_messages = 20
awareness_max_channels = 5

[concierge]
model = "claude-opus-4-8"
rotate_at_tokens = 190000
effort = ""

[quick]
enabled = true
model = "claude-sonnet-5"
effort = "medium"
sync_wait_secs = 240
hard_timeout_secs = 900
max_concurrent = 3
browser_profile_dir = "browser/profile"
browser_headless = true
browser_viewport_width = 1440
browser_viewport_height = 900
browser_launch_timeout_ms = 30000
browser_action_timeout_ms = 10000
browser_navigation_timeout_ms = 30000
browser_eval_timeout_ms = 60000
browser_max_output_chars = 24000
browser_question_wait_secs = 3600

[announce]
changes_channel_id = ""
max_commits = 20

[federation]
peers = []
peer_burst_per_min = 5
