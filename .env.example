# Beckett — secrets inventory (issue #30). The real file lives at ~/.beckett/.env on the box
# and is NEVER committed; this file is the authoritative list of which keys exist so
# `beckett doctor` can flag drift in both directions (missing required key / undocumented key).
# A trailing `# optional` marks a key the daemon can run without.

# Discord bot token (the concierge's gateway login).
DISCORD_TOKEN=

# Plane personal API token (the ticket queue at plane.0xbeckett.me).
PLANE_API_TOKEN=

# GitHub PAT for the 0xbeckett machine account (publishing project repos, PRs).
GITHUB_PAT=

# Raw Discord webhook for crash alerts + weekly heartbeat — deliberately NOT the bot token, so
# alerts still fire when the daemon (the bot) is the thing that died.
DISCORD_ALERT_WEBHOOK_URL= # optional

# Discord identity plumbing.
DISCORD_OWNER_ID= # optional
DISCORD_OWNER_NAME= # optional
BECKETT_STARTUP_CHANNEL_ID= # optional

# Cloudflare (DNS + tunnels + the edge site at 0xbeckett.me).
CLOUDFLARE_API_TOKEN= # optional
CLOUDFLARE_ZONE_ID= # optional
CLOUDFLARE_TUNNEL_ID= # optional

# Plane API reached via an internal URL (bypasses the public auth gate); links stay public.
PLANE_INTERNAL_URL= # optional

# Discord Rich Presence daemon (beckett-rpc.service).
DISCORD_RPC_CLIENT_ID= # optional
DISCORD_RPC_DETAILS= # optional
DISCORD_RPC_LARGE_IMAGE= # optional

# Overrides (defaults are right for loom-desk).
BECKETT_PROJECTS_ROOT= # optional
BECKETT_SELF_PROJECT= # optional
BECKETT_GH_ORG= # optional
BECKETT_GIT_NAME= # optional
BECKETT_GIT_EMAIL= # optional
BECKETT_LOG_LEVEL= # optional
