# Beckett — the secrets inventory (issues #30 + #34). The real file lives at ~/.beckett/.env on
# the box (mode 0600, loaded by the daemon AND by systemd EnvironmentFile=) and is NEVER
# committed. This file is the authoritative key list: `beckett doctor` flags drift in BOTH
# directions (missing required key = fail; key in .env but not documented here = warn).
# A trailing `# optional` marks a key the daemon can run without.
#
# Encrypted backup: after ANY change to the real .env, run ./deploy/backup-secrets.sh from the
# Mac (age-encrypted to ~/.beckett-backups/; restore procedure in deploy/host-setup.md).

# ── required — the daemon refuses to be useful without these ─────────────────────────────────

# Discord bot token. Mint/rotate: discord.com/developers -> your app -> Bot -> Reset Token.
# Rotation = paste the new token here + `systemctl --user restart beckett-v4.service`.
DISCORD_TOKEN=

# GitHub PAT for the configured account/org (publishes project repos and opens PRs).
# Mint: github.com/settings/tokens while signed into that account. Scopes: repo + workflow.
GITHUB_PAT=

# ── model APIs (additive tooling; not used by worker harness casts) ──────────────────────────

# OpenRouter API key — powers `beckett eval <author/model>` for provider-agnostic model evals.
# Mint: openrouter.ai → Keys. Optional: the daemon and ticket workers do not need it.
OPENROUTER_API_KEY= # optional

# ── ambient classifier (proactivity) ─────────────────────────────────────────────────────────

# Cerebras API key — powers the ambient burst classifier when config.toml sets
# `[proactivity] triage_provider = "cerebras"` (fast + cheap scoring vs spawning claude).
# Mint: cloud.cerebras.ai → API Keys. Optional: with triage_provider = "claude" it is unused.
CEREBRAS_API_KEY= # optional

# ── alerting (issue #30) ──────────────────────────────────────────────────────────────────────

# Raw Discord webhook for crash alerts + the weekly heartbeat — deliberately NOT the bot token,
# so alerts still fire when the daemon (the bot) is the thing that died. Mint: channel settings →
# Integrations → Webhooks on the ops channel.
DISCORD_ALERT_WEBHOOK_URL= # optional

# ── Discord identity plumbing ────────────────────────────────────────────────────────────────

# Discord user id for this instance's owner (required by install.sh; optional only when an
# access.txt allowlist is provisioned manually). The owner is access-list exempt.
DISCORD_OWNER_ID= # optional
DISCORD_OWNER_NAME= # optional
# Startup-banner / crash-loop-alarm channel. Set `disabled` to suppress these optional posts.
BECKETT_STARTUP_CHANNEL_ID= # optional
# Restart release-note ("what's new") channel. Set `disabled` to skip the announcement.
BECKETT_RELEASE_NOTE_CHANNEL_ID= # optional
# Channel where task/branch/subscription status cards land.
BECKETT_CARDS_CHANNEL_ID= # optional
# Legacy (v2 ambient era) — nothing in v3 reads these; safe to remove from the box .env.
DISCORD_HOME_SERVER_ID= # optional
DISCORD_LOG_CHANNEL_ID= # optional

# ── Cloudflare (DNS + tunnels + the 0xbeckett.me edge site) ──────────────────────────────────

# Mint: dash.cloudflare.com → My Profile → API Tokens. Permissions: Zone.DNS edit +
# Zone.Workers Routes edit on 0xbeckett.me, Account.Workers Scripts edit, Account.Cloudflare
# Tunnel read (the "upgraded" token per the domain memory).
CLOUDFLARE_API_TOKEN= # optional
CLOUDFLARE_ZONE_ID= # optional   (the 0xbeckett.me zone)
CLOUDFLARE_ACCOUNT_ID= # optional (wrangler deploys of web/)
CLOUDFLARE_TUNNEL_ID= # optional  (the named tunnel behind *.0xbeckett.me)

# ── ticket tracker (bored) ───────────────────────────────────────────────────────────────────

# Loopback URL of the bored tracker service (frgmt0/bored). The daemon, CLI, and doctor all
# read this; unset they use the managed-service default http://127.0.0.1:7770.
BECKETT_BORED_URL= # optional

# ── GitHub/identity extras ───────────────────────────────────────────────────────────────────

# Login authenticated by the PAT (defaults to config identity.github_user). When no
# BECKETT_GH_ORG is set, managed project repos are published under this account too.
GITHUB_ACCOUNT= # optional
# Legacy duplicates — the code sets GH_TOKEN per-invocation from GITHUB_PAT; GITHUB_USER is the
# config key `identity.github_user` now. Safe to remove from the box .env.
GH_TOKEN= # optional
GITHUB_USER= # optional

# ── Gmail (agency email; only the GMAIL_OAUTH_* names are read by code) ──────────────────────

GMAIL_OAUTH_CLIENT_ID= # optional
GMAIL_OAUTH_CLIENT_SECRET= # optional
GMAIL_OAUTH_REFRESH_TOKEN= # optional
# Legacy names present on the box (GMAIL_CLIENT_ID/GMAIL_CLIENT_SECRET/GMAIL_REFRESH_TOKEN/
# GMAIL_ADDRESS) — nothing reads them; rename to the GMAIL_OAUTH_* forms or remove.
GMAIL_ADDRESS= # optional
GMAIL_CLIENT_ID= # optional
GMAIL_CLIENT_SECRET= # optional
GMAIL_REFRESH_TOKEN= # optional

# ── Discord Rich Presence daemon (beckett-rpc.service) ───────────────────────────────────────

DISCORD_RPC_CLIENT_ID= # optional
DISCORD_RPC_DETAILS= # optional
DISCORD_RPC_LARGE_IMAGE= # optional

# ── behavior overrides (defaults are right for loom-desk) ────────────────────────────────────

BECKETT_DIR= # optional            (runtime dir; default ~/.beckett)
BECKETT_PROJECTS_ROOT= # optional  (project checkouts; default ~/Projects)
BECKETT_SELF_PROJECT= # optional   (the restricted self-repo slug; default "beckett")
# GitHub account/org that owns project repos. This takes precedence over GITHUB_ACCOUNT for repo
# ownership only; the PAT must still authenticate as GITHUB_ACCOUNT (or identity.github_user).
BECKETT_GH_ORG= # optional
BECKETT_GIT_NAME= # optional
BECKETT_GIT_EMAIL= # optional
BECKETT_LOG_LEVEL= # optional      (debug|info|warn|error)
